APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# PowerOffice Go (Z-report / ledger sync)
# -----------------------------------------------------------------------------
# Required for onboarding "Connect" and API calls. Register your app with PowerOffice.
# Docs: https://developer.poweroffice.net/documentation
# V2 URL overview: https://developer.poweroffice.net/documentation/from-v1-to-v2
#
# Reference (from PowerOffice):
#   Demo GUI:     https://godemo.poweroffice.net/
#   Prod GUI:     https://go.poweroffice.net/
#   V2 REST demo: https://goapi.poweroffice.net/demo/v2
#   V2 REST prod: https://goapi.poweroffice.net/v2
#   V2 OAuth demo: https://goapi.poweroffice.net/Demo/OAuth/Token
#   V2 OAuth prod: https://goapi.poweroffice.net/oauth/token
#
POWEROFFICE_CLIENT_ID=
POWEROFFICE_CLIENT_SECRET=

# V2: product subscription key from the PowerOffice developer portal (required on v2 auth + API calls per PowerOffice)
POWEROFFICE_SUBSCRIPTION_KEY=

# Optional: verify server-to-server onboarding callbacks (header X-PowerOffice-Callback-Secret)
POWEROFFICE_CALLBACK_SECRET=

# V2 REST API base (defaults match PowerOffice; paths like /Onboarding/... are appended in code)
# Leave unset to use defaults. Do not set to blank — empty values used to break Guzzle (cURL error 3).
# POWEROFFICE_DEMO_BASE_URL=https://goapi.poweroffice.net/demo/v2
# POWEROFFICE_PROD_BASE_URL=https://goapi.poweroffice.net/v2

# V2 OAuth token endpoints (different from REST base; demo uses capital "Demo" in path)
# POWEROFFICE_DEMO_OAUTH_TOKEN_URL=https://goapi.poweroffice.net/Demo/OAuth/Token
# POWEROFFICE_PROD_OAUTH_TOKEN_URL=https://goapi.poweroffice.net/oauth/token

# Optional: whitelisted URLs passed to PowerOffice onboarding (must match PowerOffice whitelist)
# Dev example:  https://pos-stripe.share.visivo.no/api/poweroffice/onboarding/callback
#               https://pos-stripe.share.visivo.no/integrations/poweroffice/onboarding/redirect
# Prod example: https://positiv.visivo.no/api/poweroffice/onboarding/callback
#               https://positiv.visivo.no/integrations/poweroffice/onboarding/redirect
POWEROFFICE_CALLBACK_URL=
POWEROFFICE_REDIRECT_URL=

# Optional: API path overrides (defaults match PowerOffice Go API v2 OpenAPI "Onboarding")
# POWEROFFICE_ONBOARDING_INIT_PATH=/Onboarding/Initiate
# POWEROFFICE_ONBOARDING_COMPLETE_PATH=/Onboarding/Finalize
# Manual journal POST path (PowerOffice Go API v2). Default: /Vouchers/ManualJournals (matches Go "Direktepostere manuelle bilag"). Use /JournalEntryVouchers/ManualJournals for journal-entry workflow only.
# POWEROFFICE_LEDGER_POST_PATH=/Vouchers/ManualJournals
# POWEROFFICE_LEDGER_POST_PATH=/JournalEntryVouchers/ManualJournals

# Optional: exact GET path for Client Integration Information (php artisan poweroffice:diagnose). Leave unset to try common paths.
# POWEROFFICE_CLIENT_INTEGRATION_INFO_PATH=/ClientIntegrationInformation

# -----------------------------------------------------------------------------
# Stripe — Connect balance transaction mirror (scheduled)
# -----------------------------------------------------------------------------
# When true (default), the scheduler queues SyncStoreStripeBalanceTransactionsJob
# per store (~every 30 minutes). Requires php artisan schedule:run + queue workers.
# STRIPE_SYNC_BALANCE_TRANSACTIONS_SCHEDULE=true

# -----------------------------------------------------------------------------
# POS — daily auto-close of open register sessions (disabled by default)
# -----------------------------------------------------------------------------
# Master switch for the scheduler. Per-store: Settings → Register sessions → Auto-close open sessions daily.
# POS_AUTO_CLOSE_SESSIONS_DAILY=false
# POS_AUTO_CLOSE_SESSIONS_TIME=00:30
# POS_AUTO_CLOSE_SESSIONS_NOTES="Session auto-closed by daily schedule."

# -----------------------------------------------------------------------------
# Tripletex (optional)
# -----------------------------------------------------------------------------
# Cap JSON size for stored Filament period previews (bytes). Prevents oversized
# DB writes / Livewire payloads when "resolve Tripletex accounts" embeds draft vouchers.
# TRIPLETEX_PERIOD_PREVIEW_MAX_STORED_JSON_BYTES=1500000

# -----------------------------------------------------------------------------
# FlutterFlow AI (optional — local DSL validate/run against POSitiv)
# -----------------------------------------------------------------------------
# Project settings → Integrations → FlutterFlow AI. Used by `flutterflow ai init`
# and by scripts in docs/flutterflow/dsl/ (defaults if unset: FF_API_KEY).
# Init the workspace from the pos-stripe repo root; folder name should be e.g.
# positiv_flutterflow_ai (not flutterflow_ai — pubspec/package name collision).
# FLUTTERFLOW_AI_API_KEY=
# Optional override when the cloud project id changes (default: pointofsale-xrlz5i).
# FLUTTERFLOW_POSITIV_PROJECT_ID=
# Optional: absolute path to the FlutterFlow desktop export root if not under
# ~/Library/Application Support/io.flutterflow.prod.mac/p_o_sitiv
# POSITIV_FLUTTER_EXPORT_ROOT=
#
# FlutterFlow CLI — account token (NOT the AI key above)
# -----------------------------------------------------------------------------
# https://pub.dev/packages/flutterflow_cli — `flutterflow export-code` uses the
# token from https://app.flutterflow.io/account (often named FLUTTERFLOW_API_TOKEN
# in docs). MCP / `flutterflow ai run` use FLUTTERFLOW_AI_API_KEY instead; both
# target the same cloud project, but Desktop does not always refresh until you
# pull/sync or re-export. To overwrite a local folder with exactly what the
# server has: `flutterflow export-code --project pointofsale-xrlz5i --dest <path>`.
# FLUTTERFLOW_API_TOKEN=
